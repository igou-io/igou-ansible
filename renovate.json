{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>igou-io/igou-devenv//renovate-base.json"
  ],
  "packageRules": [
    {
      "matchManagers": ["github-actions"],
      "groupName": "github-actions"
    },
    {
      "matchUpdateTypes": ["patch"],
      "groupName": "patch updates"
    },
    {
      "matchUpdateTypes": ["minor"],
      "groupName": "minor updates"
    },
    {
      "matchUpdateTypes": ["major"],
      "groupName": "major updates"
    },
    {
      "matchUpdateTypes": ["pin"],
      "groupName": "pin dependencies"
    },
    {
      "matchUpdateTypes": ["digest"],
      "groupName": "digest updates"
    },
    {
      "matchManagers": ["pip_requirements"],
      "groupName": "pip dependencies"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["docker"],
      "groupName": "ee container images",
      "minimumReleaseAge": null,
      "minimumReleaseAgeBehaviour": "age-only"
    },
    {
      "matchManagers": ["custom.regex"],
      "matchDatasources": ["github-releases", "pypi"],
      "groupName": "cli tools"
    }
  ],
  "customManagers": [
    {
      "description": "Update pinned CLI tool versions in Containerfiles and EE definitions via '# renovate:' comments",
      "customType": "regex",
      "managerFilePatterns": ["/Containerfile$/", "/Dockerfile$/", "/execution-environment\\.yml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)(?: extractVersion=(?<extractVersion>\\S+))?\\n\\s*(?:ARG )?\\w+_VERSION=\"(?<currentValue>[^\"]+)\"",
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*package_pip: \\S+==[\"']?(?<currentValue>[^\"'\\s]+)"
      ],
      "versioningTemplate": "semver"
    },
    {
      "description": "Track and pin Docker base images in execution-environment.yml files",
      "customType": "regex",
      "managerFilePatterns": ["/execution-environment\\.yml$/"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\n\\s*name: [^:\\s]+:(?<currentValue>[^@\\s]+)(?:@(?<currentDigest>\\S+))?"
      ],
      "autoReplaceStringTemplate": "# renovate: datasource={{{datasource}}} depName={{{depName}}}\n    name: {{{depName}}}:{{{newValue}}}{{#if newDigest}}@{{{newDigest}}}{{/if}}"
    }
  ]
}
