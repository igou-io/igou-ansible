---
profile: production

# Exclude files that reference roles/collections not installable in this environment
exclude_paths:
  - .ansible/
  - .tekton/  # Tekton/PaC manifests — Kubernetes CRDs, not Ansible content
  - playbooks/netbox/  # davidwittman.redis
  - playbooks/openshift_virtualization/virtualmachine-manage-testing.yml  # ansible-role-kubevirt_vm_manage
  - playbooks/openshift_virtualization/virtualmachine-tests/  # ansible-role-kubevirt_vm_manage
  - playbooks/rhel/rhsm-system-register.yml  # redhat.rhel_system_roles.rhc
  - playbooks/taint-nodes.yaml  # node_taint role
  - playbooks/zfs/  # ansible-zfs
  - roles/kubevirt_provision_survey/  # infra.controller_configuration.job_templates
  - roles/kubevirt_vm_snapshot/  # short interface + internal register/set_fact vars intentionally unprefixed for ergonomic CLI/extra_vars; lint logic via `ansible-lint -x var-naming`
  - roles/kubevirt_vm_provision/  # same: short vm_* interface + internal _kvp_* accumulators; lint logic via `ansible-lint -x var-naming`
  # role-ghapp-e2e provisioner shims import david_igou.molecule_provisioners
  # (pinned in the scenario's collections.yml, not installed in the lint env).
  # converge/verify stay linted; these three only import_playbook the external
  # collection.
  - molecule/role-ghapp-e2e/create.yml
  - molecule/role-ghapp-e2e/destroy.yml
  - molecule/role-ghapp-e2e/prepare.yml
  # playbook-grafana-kiosk provisioner shims: same david_igou.molecule_provisioners
  # situation as role-ghapp-e2e above. converge/verify/prepare_mock stay linted.
  - molecule/playbook-grafana-kiosk/create.yml
  - molecule/playbook-grafana-kiosk/destroy.yml
  - molecule/playbook-grafana-kiosk/prepare.yml
  # playbook-devenv-bootstrap: same pattern — create/destroy are pure import
  # shims; prepare additionally carries real plays (scratch disk, host preflight,
  # docker group) that stay linted locally where the collection is installed
  # (molecule dependency).
  - molecule/playbook-devenv-bootstrap/create.yml
  - molecule/playbook-devenv-bootstrap/destroy.yml
  - molecule/playbook-devenv-bootstrap/prepare.yml
  # playbook-truenas-configure_docker_containers provisioner shims: same
  # david_igou.molecule_provisioners situation as above. prepare (pure tasks,
  # no provisioner import), converge, and verify stay linted in CI.
  - molecule/playbook-truenas-configure_docker_containers/create.yml
  - molecule/playbook-truenas-configure_docker_containers/destroy.yml
  # playbook-windows-* provisioner shims (9 scenarios): same
  # david_igou.molecule_provisioners situation as above. create/prepare also
  # carry real preflight/sysprep-secret/DC-promotion plays that stay linted
  # locally where the collection is installed (molecule dependency).
  # converge/verify stay linted in CI.
  - molecule/playbook-windows-*/create.yml
  - molecule/playbook-windows-*/destroy.yml
  - molecule/playbook-windows-*/prepare.yml
  # role-windows_debloat: same david_igou.molecule_provisioners shim situation.
  # converge/verify/windows-sysprep-secrets stay linted.
  - molecule/role-windows_debloat/create.yml
  - molecule/role-windows_debloat/destroy.yml
  - molecule/role-windows_debloat/prepare.yml
  # role-windows_power provisioner shims: same david_igou.molecule_provisioners
  # situation as above. create carries a real preflight play and imports the
  # sysprep-secret play; all three only import_playbook the external collection.
  # converge/verify stay linted in CI.
  - molecule/role-windows_power/create.yml
  - molecule/role-windows_power/destroy.yml
  - molecule/role-windows_power/prepare.yml
  # role-windows_computer_use provisioner shims: same david_igou.molecule_provisioners
  # situation as above. create carries a real preflight play and imports the
  # sysprep-secret play; all three only import_playbook the external collection.
  # converge/verify stay linted in CI.
  - molecule/role-windows_computer_use/create.yml
  - molecule/role-windows_computer_use/destroy.yml
  - molecule/role-windows_computer_use/prepare.yml
  # role-windows_desktop_apps provisioner shims: same david_igou.molecule_provisioners
  # situation as above. create carries a real preflight play and imports the
  # sysprep-secret play; all three only import_playbook the external collection.
  # converge/verify/windows-sysprep-secrets stay linted in CI.
  - molecule/role-windows_desktop_apps/create.yml
  - molecule/role-windows_desktop_apps/destroy.yml
  - molecule/role-windows_desktop_apps/prepare.yml
