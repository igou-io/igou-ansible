# Managed by Ansible - example backend (config-file delivery demo).
# Delivered to the host via linux_podman_config_files and bind-mounted over
# nginx's default /etc/nginx/conf.d/default.conf.
server {
    listen 80 default_server;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    location / {
        try_files $uri $uri/ =404;
    }
}
