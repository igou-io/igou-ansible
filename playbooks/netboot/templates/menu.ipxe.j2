#!ipxe
### Managed by playbooks/netboot/deploy_assets.yml — do not edit manually.
###
### Fallback menu for unpinned hosts. The netbootxyz iPXE binary's
### :tftpmenu autoexec first chains tftp://${tftp-server}/MAC-${mac:hexraw}.ipxe
### against rb5009; if no per-host pin matches, the binary falls through
### to chain ${conn_type}://${boot_domain}/menu.ipxe which is this file.
### Choices are deliberately minimal -- pinned hosts should be the norm;
### this menu is for one-off interactive selection on the rare host
### that boots without a pin.
###
### pin_local_exit sentinel contract (with netboot_host_pins in
### igou-inventory): the binary's autoexec chains this menu
### UNCONDITIONALLY after a pin returns -- a pin's `exit 1` returns to
### the autoexec's :tftpmenu ladder, never straight to firmware. iPXE
### variables persist across chains within a boot session, so a pin's
### :local path sets `set pin_local_exit 1` before exiting; the check
### below then exits this menu instantly (and every retry of it in the
### autoexec's :menu ladder) so the host lands on the binary's
### :localboot exit to firmware without showing the generic 30s menu.

:start
isset ${pin_local_exit} && echo Pin requested local boot -- passing through to firmware ... && exit 0 ||
menu netboot.igou.systems - default Boot from local disk in 30s
item local       Boot from local disk
item ocp-add     Boot OCP add-node ISO (installs an OCP worker)
{% for entry in netboot_entries %}
item {{ entry.id }}      {{ entry.name }}
{% endfor %}
{% if _netboot_fragments | length > 0 %}
item --gap -- Custom fragments
{% for f in _netboot_fragments %}
item fragment_{{ loop.index0 }}      {{ f }}
{% endfor %}
{% endif %}
item shell       iPXE shell
choose --timeout 30000 --default local target || goto local
goto ${target}

:local
echo Booting from local disk ...
sanboot --no-describe --drive 0x80 || exit 1

:ocp-add
imgfree
initrd --name initrd {{ netboot_public_url }}/ocp-add-node/node.x86_64-initrd.img
kernel {{ netboot_public_url }}/ocp-add-node/node.x86_64-vmlinuz initrd=initrd coreos.live.rootfs_url={{ netboot_public_url }}/ocp-add-node/node.x86_64-rootfs.img rw ignition.firstboot ignition.platform.id=metal
boot

{% for entry in netboot_entries %}
:{{ entry.id }}
chain {{ netboot_public_url }}/entries/{{ entry.id }}.ipxe
goto start

{% endfor %}
{% for f in _netboot_fragments %}
:fragment_{{ loop.index0 }}
chain {{ netboot_public_url }}/fragments/{{ f }}
goto start

{% endfor %}
:shell
echo Type "exit" to return to menu.
shell
goto start
